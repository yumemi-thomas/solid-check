{
  "name": "solid-checker",
  "version": "0.1.0",
  "description": "Project-level reactivity checker and language server for Solid",
  "type": "module",
  "exports": {
    ".": {
      "types": "./wasm.d.ts",
      "import": "./wasm.mjs",
      "default": "./wasm.mjs"
    },
    "./eslint": "./eslint.cjs"
  },
  "bin": {
    "solid-check": "bin/solid-check.mjs",
    "solid-checkd": "bin/solid-checkd.mjs"
  },
  "files": [
    "bin",
    "eslint.cjs",
    "wasm.d.ts",
    "wasm.mjs",
    "native",
    "native-manifest.json",
    "scripts"
  ],
  "scripts": {
    "prepack": "node scripts/validate-package.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yumemi-thomas/solid-check.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/yumemi-thomas/solid-check/issues"
  },
  "homepage": "https://github.com/yumemi-thomas/solid-check#readme",
  "keywords": [
    "solid",
    "solidjs",
    "linter",
    "reactivity",
    "language-server"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
