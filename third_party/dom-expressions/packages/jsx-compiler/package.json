{
  "name": "@dom-expressions/jsx-compiler",
  "description": "A JSX to DOM Expressions compiler implemented with Oxc",
  "version": "0.50.0-next.20",
  "author": "Ryan Carniato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryansolid/dom-expressions.git",
    "directory": "packages/jsx-compiler"
  },
  "main": "index.js",
  "types": "types.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "types.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "napi build --release --strip --manifest-path ./Cargo.toml",
    "build:debug": "napi build --manifest-path ./Cargo.toml",
    "bench": "pnpm run build && node scripts/bench.mjs",
    "lint": "cargo clippy --manifest-path ./Cargo.toml -- -D warnings",
    "test": "pnpm run build:debug && jest --no-cache",
    "artifacts": "napi artifacts",
    "napi:version": "napi version && node ./sync-optional-deps.mjs",
    "create-npm-dirs": "napi create-npm-dirs"
  },
  "napi": {
    "binaryName": "jsx-compiler",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ],
    "wasm": {
      "browser": {
        "fs": false,
        "asyncInit": false,
        "buffer": false,
        "errorEvent": true
      }
    }
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@napi-rs/cli": "^3.7.2",
    "@napi-rs/wasm-runtime": "^1.1.6"
  },
  "optionalDependencies": {
    "@dom-expressions/jsx-compiler-darwin-x64": "0.50.0-next.20",
    "@dom-expressions/jsx-compiler-darwin-arm64": "0.50.0-next.20",
    "@dom-expressions/jsx-compiler-linux-x64-gnu": "0.50.0-next.20",
    "@dom-expressions/jsx-compiler-linux-arm64-gnu": "0.50.0-next.20",
    "@dom-expressions/jsx-compiler-win32-x64-msvc": "0.50.0-next.20",
    "@dom-expressions/jsx-compiler-wasm32-wasi": "0.50.0-next.20"
  }
}
